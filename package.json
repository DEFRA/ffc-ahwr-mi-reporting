{
  "name": "ffc-ahwr-mi-reporting",
  "version": "0.18.0",
  "description": "Azure Function to create MI reports",
  "author": "Defra",
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "start": "func start -p 7081 --verbose",
    "start:detached": "func start -p 7081 1> /dev/null 2> /dev/null &",
    "start:verbose": "func start -p 7081 --verbose",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "test:watch": "jest --coverage=false --onlyChanged --watch",
    "pretest": "npm run lint",
    "prepare": "husky"
  },
  "dependencies": {
    "@azure/ai-form-recognizer": "^4.0.0",
    "@azure/data-tables": "13.3.2",
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.13.0",
    "@hapi/wreck": "^18.0.1",
    "@pnp/nodejs-commonjs": "^2.15.0",
    "applicationinsights": "^2.9.1",
    "ffc-ahwr-common-library": "^3.7.2",
    "joi": "17.13.3",
    "moment": "2.29.4"
  },
  "overrides": {
    "@pnp/nodejs-commonjs": {
      "@azure/msal-node": "^2.9.2"
    },
    "adal-node": {
      "axios": "^1.8.2"
    },
    "jsonwebtoken": "^9.0.0",
    "node-fetch": "^2.6.7",
    "axios": "^1.8.2",
    "semver": "^7.5.2",
    "fast-xml-builder": "^1.2.0"
  },
  "devDependencies": {
    "@babel/core": "7.27.4",
    "@babel/plugin-transform-modules-commonjs": "7.27.1",
    "@babel/preset-env": "7.27.2",
    "autoprefixer": "10.4.21",
    "babel-jest": "29.7.0",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "jest": "29.7.0",
    "jest-junit": "17.0.0",
    "jest-when": "^3.6.0",
    "lint-staged": "^16.4.0",
    "standard": "17.0.0"
  },
  "homepage": "https://github.com/DEFRA/ffc-ahwr-mi-reporting",
  "repository": {
    "type": "git",
    "url": "https://github.com/DEFRA/ffc-ahwr-mi-reporting.git"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "modules": "auto"
        }
      ]
    ],
    "env": {
      "test": {
        "plugins": [
          "@babel/plugin-transform-modules-commonjs"
        ]
      }
    }
  },
  "standard": {
    "globals": [
      "describe",
      "beforeEach",
      "expect",
      "test",
      "afterEach",
      "jest",
      "beforeAll",
      "afterAll"
    ]
  },
  "lint-staged": {
    "*.js": [
      "standard --fix"
    ]
  }
}
