# Integration test environment variables
# Copy this file to .env and fill in the values before running npm run test:integration
#
# Retrieve AZURITE_KEY from the running Azurite container:
# docker ps  (find the container name)
# docker exec <azurite-container-name> node -e "const c = require('/usr/local/lib/node_modules/azurite/dist/src/common/utils/constants.js'); process.stdout.write(Buffer.from(c.EMULATOR_ACCOUNT_KEY).toString('base64'))"

AZURITE_KEY=
AZURITE_ACCOUNT=devstoreaccount1
AZURITE_HOST=127.0.0.1
AZURITE_BLOB_PORT=10005
AZURITE_TABLE_PORT=10007
